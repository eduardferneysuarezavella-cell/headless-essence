# The variables added in this file are only available locally in MiniOxygen.
# Copy to .env and fill in real values from Shopify Admin / Hydrogen setup.

PUBLIC_STOREFRONT_ID=your_storefront_id
PUBLIC_STOREFRONT_API_TOKEN=your_storefront_api_token
PUBLIC_STOREFRONT_DOMAIN=your-store.myshopify.com
PRIVATE_STOREFRONT_API_TOKEN=your_private_storefront_api_token
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=your_customer_account_client_id
PUBLIC_CUSTOMER_ACCOUNT_API_URL=https://shopify.com/your_shop_id
PUBLIC_CHECKOUT_DOMAIN=your-store.myshopify.com
SHOP_ID=your_shop_id
SESSION_SECRET=generate_a_long_random_string_for_sessions
